# Splashworks Data Warehouse — Environment Variables
# Copy to .env and fill in values

# PostgreSQL (owner — used by ETL and dbt)
DB_PASSWORD=<your-db-password>

# PostgreSQL (read-only — used by API)
DB_RO_PASSWORD=<your-ro-password>

# AI Provider API Keys (server-side, not exposed to frontend)
ANTHROPIC_API_KEY=<your-anthropic-api-key>
AI_PROVIDER=anthropic

# Cloudflare Tunnel
CLOUDFLARE_TUNNEL_TOKEN=your_tunnel_token_here
