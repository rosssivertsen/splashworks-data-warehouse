# Dependencies
node_modules
dist
dist-ssr
*.local

# Editor
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Coverage directory
coverage
*.lcov

# nyc test coverage
.nyc_output

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Build outputs
.next
.nuxt
.vuepress/dist
.serverless
.fusebox/

# Database files (keep schema, exclude binaries)
test-databases/*.db
test-databases/*.sqlite
test-databases/*.sqlite3
!test-databases/*.sql
# Ad hoc working data (extracts, spreadsheets, exports)
data/
work/

# Raw customer data — NEVER commit. Broad patterns so a stray `git add -A`
# cannot capture Skimmer extracts, BI workbooks, or recordings regardless of
# folder. See docs/SECURITY_AUDIT_2026-07-14.md. Add a `!path/file` negation
# below only for a specific file you intentionally want tracked.
Skimmer Nightly/
*.db
*.db.gz
*.sqlite
*.sqlite3
*.pbix
*.pbip
*.xlsb
*.xlsx
*.xls
*.mp4
*.msg
*.zip
!test-databases/*.sql
!infrastructure/**/*.sql

# Local Netlify folder
.netlify

# Windows thumbnail cache
Thumbs.db

# Binary data files (keep SQL queries, exclude binaries)
SQL-Semantic-Queries/*.pbix
SQL-Semantic-Queries/*.xlsb

# Python
__pycache__/
*.py[cod]
etl/.venv/
api/.venv/

# dbt artifacts
dbt/dbt_packages/
dbt/target/
dbt/logs/
dbt/.user.yml
.firecrawl/

# Security audit artifacts (Shannon pentest, Playwright snapshots)
deliverables/
.playwright-cli/
.playwright-mcp/

# Stray screenshots from browser automation
*.png
!docs/**/*.png

# Secrets / keys — NEVER commit. Broad patterns so a stray `git add -A` cannot
# capture private keys or one-off partner-comms drafts left in the working tree.
*_key
*.pem
id_ed25519*
id_rsa*
docs/greenmill*
