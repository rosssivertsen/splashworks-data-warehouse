select

a.CompanyId as CompanyId,
a.poolid as PoolId,

b.ServiceLocationId as RouteStopServiceLocationId,
b.accountid as RouteStopAccountId,
b.servicedate as RouteStopServiceDate,

c.name as PoolName,
c.gallons as PoolGallons,
c.BaselineFilterPressure as PoolBaselineFilterPressure,

d.entrytype as ServiceStopEntryEntryType,
d.Value as ServiceStopEntryValue,


e.UnitOfMeasure as EntryDescriptionUnitOfMeasure,
e.ReadingType as EntryDescriptionReadinType,
e.readingtype as EntryDescriptionReadingType,
e.dosagetype as EntryDescriptionDosageType,
e.Cost as EntryDescriptionCost,
e.price as EntryDescriptionPrice,
e.CanIncludeWithService as CanIncludeWithService

from servicestop a 

left join routestop b
            on a.RouteStopId = b.id
            and b.deleted = 0
            
left join pool c
            on a.poolid = c.id
            and b.ServiceLocationId = c.ServiceLocationId
            and c.deleted = 0
            
left join servicestopentry d
            on a.id = d.servicestopid
            and a.poolid = d.PoolId
            and b.ServiceDate = d.ServiceDate
            and d.deleted = 0
            and d.EntryType = 'Dosage'
       
            
left join entrydescription e
            on d.entrydescriptionid = e.id
            and e.deleted = 0

where  
a.deleted = 0


