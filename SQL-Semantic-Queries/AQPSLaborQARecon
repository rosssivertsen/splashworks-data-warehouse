with base as (
    select
        a.companyid as CompanyId,
        a.servicelocationid as ServiceLocationId,
        cast(strftime('%m', a.ServiceDate)as Integer) as ServiceDateMonthNum,
        cast(strftime('%Y', a.ServiceDate)as Integer) as ServiceDateYear,
        strftime('%Y-%m', a.servicedate) as ServiceDateYearMonth,
        b.customerid as CustomerId,

        case when a.starttime <> '2010-01-01 12:00:00'
                and a.completetime <> '2010-01-01 12:00:00'  then 1 else 0 
                end as ServiceStatus,
        
        case when c.displayascompany = 1 then c.CompanyName else c.LastName || ' ' || c.FirstName end as CleanCustomerName,
        
        b.address as Address,
        b.rate as Rate,
        b.ratetype as RateType,
        b.laborcost as LaborCost,
        b.laborcosttype as LaborCostType,
        
        (e.value * f.cost) as DosageCost,
        (e.value * f.price) as DosagePrice


from routestop a
   
left join servicelocation b
           on a.servicelocationid = b.id
          and b.deleted = 0
       

left join customer c
            on b.customerid = c.id
            and c.deleted = 0

left join servicestop d
            on a.id = d.routestopid
            and a.servicedate = d.servicedate
            and b.deleted = 0

left join servicestopentry e
            on d.id = e.servicestopid
            and d.poolid = e.poolid
            and d.servicedate = e.servicedate
            and e.entryType = 'Dosage'
            and e.deleted = 0

left join entrydescription f
            on e.entrydescriptionid = f.id
            and f.deleted = 0

            
where a.deleted = 0

)

select
    CompanyId,
    CustomerId,
    ServiceDateMonthNum,
    ServiceDateYear,
    ServiceStatus,
    CleanCustomerName,
    Address,
    Rate,
    RateType,
    LaborCost,
    LaborCostType,
    DosageCost,
    DosagePrice,
  
    sum(ServiceStatus) over (
            partition by ServiceLocationId, ServiceDateYearMonth
    ) as TotalCountPerMonth

from base
where ServiceStatus = 1


;
