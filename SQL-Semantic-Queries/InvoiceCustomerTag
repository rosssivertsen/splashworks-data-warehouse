SELECT 
    CASE 
        WHEN a.displayascompany = 1 
            THEN a.CompanyName 
        ELSE a.LastName || ' , ' || a.FirstName 
    END AS CleanCustomerName,

    c.name AS TagName,

    CASE 
        WHEN MAX(
            CASE WHEN c.name LIKE '%Russells%' THEN 1 ELSE 0 END
        ) OVER (
            PARTITION BY 
                CASE 
                    WHEN a.displayascompany = 1 THEN a.CompanyName 
                    ELSE a.LastName || ' , ' || a.FirstName 
                END
        ) = 1
        THEN 'Russell''s'
        ELSE 'A Quality Pool Service'
    END AS CleanTagName

FROM customer a

LEFT JOIN customertag b
       ON a.id = b.customerid
      AND b.deleted = 0

LEFT JOIN tag c
       ON b.tagid = c.id
      AND c.deleted = 0

WHERE a.deleted = 0;
